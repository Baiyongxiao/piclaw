  "name": "web",
  "version": "0.6.18",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
